{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Insty",
  "scopeName": "source.insty",
  "fileTypes": ["ins"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#compile-time" },
    { "include": "#module" },
    { "include": "#imports" },
    { "include": "#declarations" },
    { "include": "#attributes" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#cast" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#function-call" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.insty",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.insty",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "compile-time": {
      "patterns": [
        {
          "name": "keyword.control.directive.conditional.insty",
          "match": "#\\b(if|else)\\b"
        }
      ]
    },
    "module": {
      "begin": "\\b(module)\\b",
      "beginCaptures": {
        "1": { "name": "keyword.control.module.insty" }
      },
      "end": "$",
      "patterns": [
        {
          "name": "entity.name.namespace.insty",
          "match": "[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "imports": {
      "begin": "\\b(import)\\b",
      "beginCaptures": {
        "1": { "name": "keyword.control.import.insty" }
      },
      "end": "$",
      "patterns": [
        { "include": "#comments" },
        { "name": "keyword.control.import.insty", "match": "\\b(as)\\b" },
        {
          "name": "keyword.operator.namespace.insty",
          "match": "::|\\."
        },
        {
          "name": "variable.other.wildcard.insty",
          "match": "\\*"
        },
        {
          "name": "entity.name.namespace.insty",
          "match": "[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(fun)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.function.insty" },
            "2": { "name": "entity.name.function.insty" }
          }
        },
        {
          "match": "\\b(struct|class|enum)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.type.insty" },
            "2": { "name": "entity.name.type.insty" }
          }
        },
        {
          "name": "keyword.declaration.insty",
          "match": "\\b(constructor|destructor|operator|section)\\b"
        }
      ]
    },
    "attributes": {
      "comment": "Declaration attributes like fun [name(x), mangle(off)]",
      "patterns": [
        {
          "match": "(?<=\\b(?:fun|struct|class|section)\\b[^\\[\\n]*)(\\[)([^\\]]*)(\\])",
          "captures": {
            "1": { "name": "punctuation.definition.attribute.insty" },
            "2": { "name": "meta.attribute.insty" },
            "3": { "name": "punctuation.definition.attribute.insty" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.insty",
          "match": "\\b(if|else|while|for|loop|when|switch|return|break|skip)\\b"
        },
        {
          "name": "keyword.other.memory.insty",
          "match": "\\b(new|delete)\\b"
        },
        {
          "name": "storage.modifier.insty",
          "match": "\\b(const|let|unsafe|volatile)\\b"
        },
        {
          "name": "variable.language.this.insty",
          "match": "\\b(this)\\b"
        }
      ]
    },
    "cast": {
      "match": "\\b(cast)\\s*(<)",
      "captures": {
        "1": { "name": "keyword.operator.cast.insty" },
        "2": { "name": "punctuation.definition.generic.begin.insty" }
      }
    },
    "builtins": {
      "name": "support.function.builtin.insty",
      "match": "@(syscall|sizeof|alignof|offsetof|typeof|bitcast|inttoptr|ptrtoint|malloc|realloc|free|memcpy|memset|strlen|panic|readFile|system|getCurrentOS|print|println|utf8|utf16|builtin|name)\\b"
    },
    "strings": {
      "name": "string.quoted.double.insty",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.insty",
          "match": "\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|[0nrtbfv\\\\\"'\\$])"
        },
        {
          "name": "meta.interpolation.insty",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.interpolation.begin.insty" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.interpolation.end.insty" }
          },
          "patterns": [
            { "include": "#builtins" },
            { "include": "#keywords" },
            { "include": "#numbers" },
            { "include": "#operators" },
            { "include": "#function-call" },
            { "include": "#identifiers" }
          ]
        },
        {
          "name": "meta.interpolation.insty",
          "match": "(\\$)([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": { "name": "punctuation.definition.interpolation.begin.insty" },
            "2": { "name": "variable.other.interpolated.insty" }
          }
        }
      ]
    },
    "chars": {
      "name": "string.quoted.single.insty",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.insty",
          "match": "\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|[0nrtbfv\\\\\"'])"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.insty",
          "match": "\\b0[xX][0-9A-Fa-f_]+\\b"
        },
        {
          "name": "constant.numeric.binary.insty",
          "match": "\\b0[bB][01_]+\\b"
        },
        {
          "name": "constant.numeric.octal.insty",
          "match": "\\b0[oO][0-7_]+\\b"
        },
        {
          "name": "constant.numeric.float.insty",
          "match": "\\b[0-9][0-9_]*\\.[0-9_]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.insty",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "name": "constant.language.insty",
      "match": "\\b(true|false)\\b"
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.insty",
          "match": "\\b(void|bool|text|string|i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f16|f32|f64|f128)\\b"
        },
        {
          "comment": "User type used in a generic position: Foo<...>",
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\s*(?=<)",
          "captures": {
            "1": { "name": "entity.name.type.insty" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.namespace.insty",
          "match": "::"
        },
        {
          "name": "keyword.operator.comparison.insty",
          "match": "(==|!=|<=|>=)"
        },
        {
          "name": "keyword.operator.logical.insty",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.bitwise.insty",
          "match": "(<<|>>|&|\\||\\^|~)"
        },
        {
          "name": "keyword.operator.arrow.insty",
          "match": "->"
        },
        {
          "name": "keyword.operator.assignment.insty",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.insty",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.comparison.insty",
          "match": "(<|>)"
        }
      ]
    },
    "function-call": {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.insty" }
      }
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.type.insty",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "variable.other.insty",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
